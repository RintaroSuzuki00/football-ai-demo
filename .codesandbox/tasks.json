{
  "$schema": "https://codesandbox.io/schemas/tasks.json",
  "setupTasks": [
    {
      "name": "Install Frontend Dependencies",
      "command": "cd frontend && npm install"
    }
  ],
  "tasks": {
    "start-frontend": {
      "name": "Run React App (port 5173)",
      "command": "cd frontend && npm run dev",
      "runAtStart": true
    }
  }
}
